generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
}

enum CarStatus {
  AVAILABLE
  RESERVED
  SOLD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id                    String   @id @default("site_settings")
  heroTitle             String
  heroSubtitle          String
  heroBgImage           String
  heroPrimaryCtaLabel   String
  heroPrimaryCtaHref    String
  heroSecondaryCtaLabel String
  heroSecondaryCtaHref  String
  aboutTitle            String
  aboutText             String
  aboutImage            String
  phoneWhatsapp         String
  phoneDisplay          String
  contactEmail          String
  address               String
  instagramUrl          String
  businessHours         String
  updatedAt             DateTime @updatedAt
}

model Car {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  brand        String
  model        String
  year         Int
  km           Int
  priceCents   Int
  description  String
  modsJson     String
  featuresJson String
  tagsJson     String
  fuel         String?
  transmission String?
  status       CarStatus   @default(AVAILABLE)
  isFeatured   Boolean     @default(false)
  whatsappLink String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  images       CarImage[]
}

model CarImage {
  id        String @id @default(cuid())
  carId     String
  url       String
  alt       String
  sortOrder Int    @default(0)
  car       Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, sortOrder])
}

model PartCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     PartItem[]
}

model PartItem {
  id          String       @id @default(cuid())
  categoryId  String
  name        String
  slug        String       @unique
  description String
  imageUrl    String?
  isFeatured  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    PartCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}
