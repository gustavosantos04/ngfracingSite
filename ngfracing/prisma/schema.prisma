generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  ADMIN
}

enum CarStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum ProductCategory {
  PART
  APPAREL
  ACCESSORY
}

enum OrderStatus {
  NEW
  CONTACTED
  CLOSED
  CANCELED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id                    String   @id @default("site_settings")
  heroTitle             String
  heroSubtitle          String
  heroBgImage           String
  heroPrimaryCtaLabel   String
  heroPrimaryCtaHref    String
  heroSecondaryCtaLabel String
  heroSecondaryCtaHref  String
  aboutTitle            String
  aboutText             String
  aboutImage            String
  phoneWhatsapp         String
  phoneDisplay          String
  contactEmail          String
  address               String
  instagramUrl          String
  businessHours         String
  updatedAt             DateTime @updatedAt
}

model Car {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  brand        String
  model        String
  year         Int
  km           Int
  priceCents   Int
  description  String
  modsJson     String
  featuresJson String
  tagsJson     String
  fuel         String?
  transmission String?
  status       CarStatus   @default(AVAILABLE)
  isFeatured   Boolean     @default(false)
  whatsappLink String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  images       CarImage[]
}

model CarImage {
  id        String @id @default(cuid())
  carId     String
  url       String
  alt       String
  sortOrder Int    @default(0)
  car       Car    @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, sortOrder])
}

model Product {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  category        ProductCategory
  description     String
  priceCents      Int
  primaryImageUrl String
  galleryJson     String          @default("[]")
  stockQuantity   Int?
  sizeStockJson   String          @default("[]")
  isFeatured      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category, createdAt])
}

model Order {
  id                      String      @id @default(cuid())
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  status                  OrderStatus @default(NEW)
  customerName            String
  customerEmail           String
  customerPhone           String
  customerAddress         String
  productId               String
  productNameSnapshot     String
  productCategorySnapshot String
  productPriceSnapshot    Int
  quantity                Int
  selectedSize            String?
  notes                   String?

  @@index([status, createdAt])
  @@index([productId, createdAt])
}
